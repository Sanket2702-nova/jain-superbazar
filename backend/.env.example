# ========================================
# JAIN SUPER BAZAR - BACKEND CONFIGURATION
# ========================================

# DATABASE CONFIGURATION
# For local MongoDB: mongodb://localhost:27017/jain-super-bazar
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/jain-super-bazar
MONGODB_URI=mongodb://localhost:27017/jain-super-bazar

# SERVER PORT
# Default: 5000
# Change if port is already in use
PORT=5000

# JWT CONFIGURATION
# Change this to a strong, random string for production!
# Example: openssl rand -base64 32
JWT_SECRET=your_secret_key_here_change_in_production

# ENVIRONMENT
# Values: development, production
# Set to development for detailed error messages
NODE_ENV=development

# ========================================
# SETUP INSTRUCTIONS:
# 1. Install MongoDB locally or use MongoDB Atlas
# 2. Update MONGODB_URI with your actual connection string
# 3. Change JWT_SECRET to a strong random string
# 4. Set NODE_ENV to production when deploying
# =========================================
