{
  "name": "jain-super-bazar",
  "version": "1.0.0",
  "description": "Full-stack e-commerce grocery store",
  "private": true,
  "scripts": {
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ..",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "seed": "cd backend && npm run seed",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": [
    "ecommerce",
    "grocery",
    "shopping",
    "react",
    "express",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT"
}
